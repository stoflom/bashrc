# Calculate disk usage for all files in the current/specified directory (including hidden files)
dus ()
{
    local dir="${1:-.}" # Use argument 1, or the current directory if no argument is given
    local dotglob_status=0
    
    # Check if dotglob is currently set. $() is a command substitution, 
    # but the check is simpler:
    if shopt -q dotglob; then
        dotglob_status=1 # If already set, remember to NOT unset it later.
    else
        # Enable dotglob: this makes * also match files starting with a dot (hidden files).
        shopt -s dotglob
    fi
    
    # Check if we are running in the current directory or a specific one
    if [ "$dir" = "." ]; then
        echo ":"
        # The * glob now includes hidden files (except . and ..).
        # We use 'du -hs *' inside a subshell to execute the command with the new shopt setting.
        # We use a subshell to avoid affecting the user's shell environment.
        ( du -hs * )
    else
        echo "Calculating disk usage for all files in directory: $dir (including hidden files):"
        # Since we pass the directory as an argument, we need to glob its contents explicitly.
        # We use a subshell for the same reason.
        ( du -hs "$dir"/* )
    fi

    # Restore dotglob to its original state *only if* we set it
    if [ $dotglob_status -eq 0 ] && [ "$dir" = "." ]; then
        shopt -u dotglob
    fi
    
    # NOTE: Because we ran the du command inside a subshell `( du -hs ... )`, 
    # the shopt -s dotglob only applies to that subshell, so the explicit 
    # shopt -u dotglob cleanup might not be strictly necessary, but it's 
    # good practice if the function were changed to not use a subshell.
}
